{
	"$schema": "https://schema.tauri.app/config/2.4.0",
	"productName": "Taburetka",
	"identifier": "Taburetka-v1",
	"version": "1.0.0",
	"build": {
		"beforeBuildCommand": "yarn build",
		"beforeDevCommand": "yarn dev",
		"devUrl": "http://localhost:80",
		"frontendDist": "../build"
	},
	"app": {
		"security": {
			"csp": null
		},
		"windows": [
			{
				"title": "Taburetka",
				"fullscreen": false,
				"resizable": false,
				"width": 500,
				"height": 200,
				"decorations": false,
				"transparent": true,
				"shadow": false,
				"windowEffects": {
					"color": {
						"alpha": 0,
						"blue": 0,
						"green": 0,
						"red": 0
					},
					"radius": 0,
					"effects": []
				},
				"backgroundColor": "#050505"
			}
		],
		"withGlobalTauri": false
	},
	"bundle": {
		"active": true,
		"targets": "msi",
		"publisher": "sharkevichdev",
		"windows": {
			"webviewInstallMode": {
				"type": "offlineInstaller"
			}
		},
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}